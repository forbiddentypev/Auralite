{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Auralite",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "Auralite.sln",
                "/p:Configuration=Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile"]
        },
        {
            "label": "Run Sandbox",
            "type": "shell",
            "command": ".\\bin\\Debug-windows-x86_64\\Sandbox\\Sandbox.exe",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Stop Sandbox",
            "type": "shell",
            "command": "taskkill",
            "args": [
                "/F",
                "/IM",
                "Sandbox.exe"
            ],
            "problemMatcher": []
        }
    ]
}
